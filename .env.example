## Copy to `.env` and fill values (do not commit `.env`)

# Used if you want Add Client to NOT ask for an API key every time.
# Either DEFAULT_CWP_API_KEY or CWP_API_KEY can be set (both supported).
DEFAULT_CWP_API_KEY=PUT_YOUR_CWP_API_KEY_HERE
CWP_API_KEY=PUT_YOUR_CWP_API_KEY_HERE

# Strong random string to sign login sessions (prevents frequent logouts on restart).
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# FTP control socket timeout (ms). Increase if you see "Timeout (control socket)".
# 15 minutes = 900000
FTP_CONTROL_TIMEOUT_MS=900000

# Hard timeouts for FTP LIST and individual file downloads (ms).
# Useful when an FTP server/firewall drops passive-mode data connections and LIST/download hangs.
FTP_LIST_TIMEOUT_MS=45000
FTP_FILE_TIMEOUT_MS=300000

# Workarounds for finicky FTP servers.
# If directory listing fails, try forcing LIST instead of MLSD.
FTP_USE_MLSD=true
# If needed, disable EPSV (forces PASV).
FTP_DISABLE_EPSV=false
# If LIST still times out after disabling EPSV, the server is likely behind NAT and
# advertising its internal IP in the PASV response. Enable this to override the
# advertised IP with the control socket's actual remote IP.
FTP_PASV_USE_CTRL_IP=false

# Safety: by default we treat FTP remote path "/" as "/public_html" because scanning
# the FTP root often hangs or is huge. Set true to allow scanning "/".
FTP_ALLOW_ROOT=false
