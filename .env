## Copy to `.env` and fill values (do not commit `.env`)

# Used if you want Add Client to NOT ask for an API key every time.
# Either DEFAULT_CWP_API_KEY or CWP_API_KEY can be set (both supported).

# Strong random string to sign login sessions (prevents frequent logouts on restart).
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

CWP_API_KEY=LZA0unGH1oE6VQeJTwQBcq1bnITnSPvS5Rsd05a3LhMi6Ote8vSQScENDssfOIAOjEwdSp

# FTP control socket timeout (ms). Increase if you see "Timeout (control socket)".
# 30 minutes = 1800000
FTP_CONTROL_TIMEOUT_MS=1800000

# Hard timeouts (ms) for FTP LIST and each file download.
FTP_LIST_TIMEOUT_MS=20000
FTP_FILE_TIMEOUT_MS=60000
FTP_CONCURRENCY=1

# Workarounds for finicky FTP servers.
FTP_USE_MLSD=false
FTP_DISABLE_EPSV=true
# If LIST still times out (server advertises its internal/NAT IP in PASV response),
# enable this to force the data connection to use the control socket's IP instead.
FTP_PASV_USE_CTRL_IP=true

# Allow scanning FTP root "/" instead of forcing "/public_html"
FTP_ALLOW_ROOT=true
